--- SECTION 25: STORE (FILE I/O)
--- ============================================================
>! "";
>! "=== SECTION 25: STORE (FILE I/O) ===";

s: st_path    = "test_output/xcx_test_file.txt";
s: st_content = "Hello from XCX store test";

b: st_written = store.write(st_path, st_content);
run_assert(st_written, "store.write returns true");
run_assert(store.exists(st_path), "store.exists after write");

s: st_read = store.read(st_path);
run_assert_eq_s(st_read, st_content, "store.read matches written");

b: st_appended = store.append(st_path, "\nSecond line");
run_assert(st_appended, "store.append returns true");

s: st_read2 = store.read(st_path);
run_assert(st_read2 HAS "Second line", "store.read after append has second line");

b: st_deleted = store.delete(st_path);
run_assert(st_deleted, "store.delete returns true");
run_assert(NOT store.exists(st_path), "store.exists false after delete");

--- ============================================================
--- SECTION 26: HALT SYSTEM
--- ============================================================
>! "";
>! "=== SECTION 26: HALT SYSTEM ===";

halt.alert >! "halt.alert test - this is a warning (execution continues)";
run_assert(true, "halt.alert does not stop execution");

--- halt.error is a FATAL program terminator and cannot be caught or returned from.
--- We verify halt.alert works (execution continues) and halt.error behavior
--- is tested separately in xcx_runner.rs unit tests.
--- The following tests valid non-error paths only.

func hl_test_valid(i: hl_n -> i) {
    if (hl_n > 0) then;
        return 100 / hl_n;
    end;
    return -1;
};

i: hl_ok = hl_test_valid(5);
run_assert_eq_i(hl_ok, 20, "no halt: 100/5 = 20");

i: hl_guard = hl_test_valid(0);
run_assert_eq_i(hl_guard, -1, "guard prevents div-by-zero");


