--- SECTION 22: JSON
--- ============================================================
>! "";
>! "=== SECTION 22: JSON ===";

json: js_cfg <<< {"port": 8080, "debug": false, "host": "localhost"} >>>;

run_assert(js_cfg.exists("port"), "json exists port");
run_assert(NOT js_cfg.exists("missing"), "json not exists missing");

i: js_port;
js_cfg.bind("port", js_port);
run_assert_eq_i(js_port, 8080, "json bind port = 8080");

s: js_host;
js_cfg.bind("host", js_host);
run_assert_eq_s(js_host, "localhost", "json bind host = localhost");

js_cfg.set("port", 9090);
i: js_new_port;
js_cfg.bind("port", js_new_port);
run_assert_eq_i(js_new_port, 9090, "json set port -> 9090");

--- nested json
json: js_nested <<< {"server": {"host": "example.com", "port": 443}} >>>;
s: js_nested_host;
js_nested.bind("server.host", js_nested_host);
run_assert_eq_s(js_nested_host, "example.com", "json nested bind");

--- size / count
json: js_obj <<< {"a": 1, "b": 2, "c": 3} >>>;
run_assert_eq_i(js_obj.size(), 3, "json size = 3");

--- to_str
json: js_serial <<< {"key": "val"} >>>;
s: js_str = js_serial.to_str();
run_assert(js_str HAS "key", "json to_str contains key");

--- json parse
s: js_raw = "{\"name\": \"Alice\", \"age\": 30}";
json: js_parsed = json.parse(js_raw);
s: jp_name;
js_parsed.bind("name", jp_name);
run_assert_eq_s(jp_name, "Alice", "json parse bind name = Alice");

--- ============================================================
--- SECTION 23: DATES
--- ============================================================
>! "";
>! "=== SECTION 23: DATES ===";

date: dt_christmas = date("2024-12-25");
date: dt_halloween = date("2024-10-31");
date: dt_custom    = date("25/12/2024", "DD/MM/YYYY");

run_assert_eq_i(dt_christmas.year,  2024, "date year = 2024");
run_assert_eq_i(dt_christmas.month, 12,   "date month = 12");
run_assert_eq_i(dt_christmas.day,   25,   "date day = 25");

--- custom format parse
run_assert_eq_i(dt_custom.year,  2024, "custom fmt year = 2024");
run_assert_eq_i(dt_custom.month, 12,   "custom fmt month = 12");
run_assert_eq_i(dt_custom.day,   25,   "custom fmt day = 25");

--- date.now()
date: dt_now = date.now();
run_assert(dt_now.year >= 2024, "date.now year >= 2024");
run_assert(dt_now.month >= 1 AND dt_now.month <= 12, "date.now month in 1..12");
run_assert(dt_now.day   >= 1 AND dt_now.day   <= 31, "date.now day in 1..31");
run_assert(dt_now.hour  >= 0 AND dt_now.hour  <= 23, "date.now hour in 0..23");

--- arithmetic
date: dt_tomorrow  = dt_christmas + 1;
date: dt_yesterday = dt_christmas - 1;
run_assert_eq_i(dt_tomorrow.day,  26, "date + 1 = 26");
run_assert_eq_i(dt_yesterday.day, 24, "date - 1 = 24");

--- difference in days
i: dt_diff = dt_christmas - dt_halloween;
run_assert_eq_i(dt_diff, 55, "christmas - halloween = 55 days");

--- comparison
b: dt_before = dt_halloween < dt_christmas;
run_assert(dt_before, "halloween < christmas");
run_assert(NOT (dt_christmas < dt_halloween), "NOT christmas < halloween");

--- formatting
s: dt_fmt1 = dt_christmas.format();
run_assert(dt_fmt1 HAS "2024", "format() contains 2024");

s: dt_fmt2 = dt_christmas.format("DD/MM/YYYY");
run_assert_eq_s(dt_fmt2, "25/12/2024", "format DD/MM/YYYY");

--- ============================================================
--- SECTION 24: CRYPTO
--- ============================================================
>! "";
>! "=== SECTION 24: CRYPTO ===";

s: cr_token = crypto.token(32);
run_assert_eq_i(cr_token.length, 32, "crypto.token(32) length = 32");

s: cr_token64 = crypto.token(64);
run_assert_eq_i(cr_token64.length, 64, "crypto.token(64) length = 64");

--- bcrypt hash and verify
s: cr_pass   = "secret123";
s: cr_hash_b = crypto.hash(cr_pass, "bcrypt");
b: cr_valid_b = crypto.verify(cr_pass, cr_hash_b, "bcrypt");
run_assert(cr_hash_b.length > 0,  "bcrypt hash not empty");
run_assert(cr_valid_b,             "bcrypt verify valid password");

b: cr_invalid_b = crypto.verify("wrongpass", cr_hash_b, "bcrypt");
run_assert(NOT cr_invalid_b, "bcrypt verify invalid password");

--- argon2 hash and verify
s: cr_hash_a  = crypto.hash(cr_pass, "argon2");
b: cr_valid_a = crypto.verify(cr_pass, cr_hash_a, "argon2");
run_assert(cr_hash_a.length > 0,  "argon2 hash not empty");
run_assert(cr_valid_a,             "argon2 verify valid password");

b: cr_invalid_a = crypto.verify("wrongpass", cr_hash_a, "argon2");
run_assert(NOT cr_invalid_a, "argon2 verify invalid password");

