--- ============================================================
--- SECTION 12: BREAK AND CONTINUE
--- ============================================================
>! "";
>! "=== SECTION 12: BREAK AND CONTINUE ===";

i: bc_sum = 0;
for bc_n in 1 to 10 do;
    if (bc_n == 6) then; break; end;
    bc_sum = bc_sum + bc_n;
end;
run_assert_eq_i(bc_sum, 15, "break at 6: sum 1..5 = 15");

i: cont_sum = 0;
for cn_n in 1 to 5 do;
    if (cn_n % 2 == 0) then; continue; end;
    cont_sum = cont_sum + cn_n;
end;
run_assert_eq_i(cont_sum, 9, "continue skip evens: 1+3+5 = 9");

--- ============================================================
--- SECTION 13: FUNCTIONS
--- ============================================================
>! "";
>! "=== SECTION 13: FUNCTIONS ===";

func fn_add(i: fn_x, i: fn_y -> i) {
    return fn_x + fn_y;
};

func fn_greet(s: fn_who) {
    >! "Hello " + fn_who;
};

func fn_get_pi(-> f) {
    return 3.14159;
};

func fn_factorial(i: fn_n -> i) {
    if (fn_n <= 1) then;
        return 1;
    else;
        return fn_n * fn_factorial(fn_n - 1);
    end;
};

run_assert_eq_i(fn_add(3, 4), 7,   "fn add(3,4) = 7");
run_assert(fn_get_pi() > 3.14,     "fn get_pi > 3.14");
run_assert_eq_i(fn_factorial(5), 120, "fn factorial(5) = 120");
fn_greet("World");

--- ============================================================
--- SECTION 14: FIBERS - TYPED
--- ============================================================
>! "";
>! "=== SECTION 14: FIBERS - TYPED ===";

fiber fb_counter(i: fb_max -> i) {
    for fb_ci in 1 to fb_max do;
        yield fb_ci;
    end;
    return 0;
};

fiber:i: fb_gen = fb_counter(3);

i: fb_v1 = fb_gen.next();
i: fb_v2 = fb_gen.next();
i: fb_v3 = fb_gen.next();

run_assert_eq_i(fb_v1, 1, "fiber first yield = 1");
run_assert_eq_i(fb_v2, 2, "fiber second yield = 2");
run_assert_eq_i(fb_v3, 3, "fiber third yield = 3");
run_assert(NOT fb_gen.isDone(), "fiber not done yet");
i: fb_v4 = fb_gen.next();
run_assert(fb_gen.isDone(), "fiber isDone after exhausted");

--- fiber iteration with for loop
i: fb_sum = 0;
fiber:i: fb_gen2 = fb_counter(5);
for fb_val in fb_gen2 do;
    fb_sum = fb_sum + fb_val;
end;
run_assert_eq_i(fb_sum, 15, "fiber for loop sum 1..5 = 15");

--- ============================================================
--- SECTION 15: FIBERS - VOID
--- ============================================================
>! "";
>! "=== SECTION 15: FIBERS - VOID ===";

fiber fb_void_printer(s: fb_msg) {
    >! "void fiber: " + fb_msg;
    yield;
    >! "void fiber done";
};

fiber: fb_void = fb_void_printer("test");
b: fb_run1 = fb_void.run();
run_assert(fb_run1, "void fiber run returns true");
run_assert(NOT fb_void.isDone(), "void fiber not done after 1 step");
fb_void.run();
run_assert(fb_void.isDone(), "void fiber done after 2nd run");

--- ============================================================
--- SECTION 16: FIBERS - YIELD FROM
--- ============================================================
>! "";
>! "=== SECTION 16: FIBERS - YIELD FROM ===";

fiber yf_base(i: yf_n -> i) {
    for yf_i in 1 to yf_n do;
        yield yf_i;
    end;
    return 0;
};

fiber yf_delegator(-> i) {
    fiber:i: yf_sub = yf_base(3);
    yield from yf_sub;
    yield 100;
    return 0;
};

fiber:i: yf_d = yf_delegator();
i: yfd_a = yf_d.next();
i: yfd_b = yf_d.next();
i: yfd_c = yf_d.next();
i: yfd_d = yf_d.next();

run_assert_eq_i(yfd_a, 1,   "yield from: 1st = 1");
run_assert_eq_i(yfd_b, 2,   "yield from: 2nd = 2");
run_assert_eq_i(yfd_c, 3,   "yield from: 3rd = 3");
run_assert_eq_i(yfd_d, 100, "yield from: 4th = 100");

--- ============================================================
--- SECTION 17: FIBER CLOSE
--- ============================================================
>! "";
>! "=== SECTION 17: FIBER CLOSE ===";

fiber fc_gen(-> i) {
    yield 1;
    yield 2;
    yield 3;
    return 0;
};

fiber:i: fc_f = fc_gen();
fc_f.next();
fc_f.close();
run_assert(fc_f.isDone(), "fiber close -> isDone");

--- break in for loop auto-closes fiber
fiber fc_gen2(-> i) {
    yield 10;
    yield 20;
    yield 30;
    return 0;
};

fiber:i: fc_f2 = fc_gen2();
for fc_v in fc_f2 do;
    if (fc_v == 10) then; break; end;
end;
run_assert(fc_f2.isDone(), "break in for auto-closes fiber");

--- ============================================================
--- SECTION 18: ARRAYS
--- ============================================================
>! "";
>! "=== SECTION 18: ARRAYS ===";

array:i: ar_nums {5, 2, 8, 1, 9};

run_assert_eq_i(ar_nums.size(), 5,   "array size = 5");
run_assert_eq_i(ar_nums.get(0), 5,   "array get(0) = 5");
run_assert_eq_i(ar_nums.get(4), 9,   "array get(4) = 9");
run_assert(ar_nums.contains(8),      "array contains 8");
run_assert(NOT ar_nums.contains(99), "array not contains 99");
run_assert_eq_i(ar_nums.find(8), 2,  "array find(8) = 2");
run_assert_eq_i(ar_nums.find(99), -1,"array find(99) = -1");
run_assert(NOT ar_nums.isEmpty(),    "array not empty");

ar_nums.push(42);
run_assert_eq_i(ar_nums.size(), 6,   "array push -> size 6");
run_assert_eq_i(ar_nums.get(5), 42,  "array push -> get(5) = 42");

i: ar_popped = ar_nums.pop();
run_assert_eq_i(ar_popped, 42,       "array pop = 42");
run_assert_eq_i(ar_nums.size(), 5,   "array pop -> size 5");

ar_nums.insert(0, 99);
run_assert_eq_i(ar_nums.get(0), 99,  "array insert at 0 = 99");

ar_nums.update(0, 77);
run_assert_eq_i(ar_nums.get(0), 77,  "array update(0,77)");

ar_nums.delete(0);
run_assert_eq_i(ar_nums.size(), 5,   "array delete(0) -> size 5");

ar_nums.sort();
i: ar_s0 = ar_nums.get(0);
run_assert(ar_s0 <= ar_nums.get(1),  "array sorted ascending");

ar_nums.reverse();
i: ar_r0 = ar_nums.get(0);
run_assert(ar_r0 >= ar_nums.get(1),  "array reversed descending");

--- clear
array:i: ar_clear {1, 2, 3};
ar_clear.clear();
run_assert(ar_clear.isEmpty(), "array clear -> isEmpty");

--- for loop over array
i: ar_iter_sum = 0;
array:i: ar_iter {10, 20, 30};
for ar_el in ar_iter do;
    ar_iter_sum = ar_iter_sum + ar_el;
end;
run_assert_eq_i(ar_iter_sum, 60, "array for loop sum = 60");

--- string array
array:s: ar_strs {"alpha", "beta", "gamma"};
run_assert_eq_s(ar_strs.get(1), "beta", "string array get(1) = beta");

--- ============================================================
--- SECTION 19: SETS
--- ============================================================
>! "";
>! "=== SECTION 19: SETS ===";

set:N: st_small {1,,5};
run_assert_eq_i(st_small.size(), 5, "set range 1..5 size = 5");
run_assert(st_small.contains(3),    "set contains 3");
run_assert(NOT st_small.contains(6),"set not contains 6");
run_assert(NOT st_small.isEmpty(),  "set not empty");

--- explicit values and deduplication
set:Z: st_dedup {1, 2, 2, 3, 3, 3};
run_assert_eq_i(st_dedup.size(), 3, "set dedup size = 3");

--- add and remove
set:N: st_mutable {10, 20, 30};
st_mutable.add(40);
run_assert(st_mutable.contains(40), "set add 40");
st_mutable.remove(10);
run_assert(NOT st_mutable.contains(10), "set remove 10");

--- clear
st_mutable.clear();
run_assert(st_mutable.isEmpty(), "set clear -> isEmpty");

--- set operations
set:N: st_a {1,,5};
set:N: st_b {3,,7};

set:N: st_union   = st_a UNION st_b;
set:N: st_inter   = st_a INTERSECTION st_b;
set:N: st_diff    = st_a DIFFERENCE st_b;
set:N: st_sym     = st_a SYMMETRIC_DIFFERENCE st_b;

run_assert_eq_i(st_union.size(), 7,   "UNION size = 7");
run_assert_eq_i(st_inter.size(), 3,   "INTERSECTION {3,4,5} size = 3");
run_assert_eq_i(st_diff.size(), 2,    "DIFFERENCE {1,2} size = 2");
run_assert_eq_i(st_sym.size(), 4,     "SYM_DIFF {1,2,6,7} size = 4");

--- Unicode operators
set:N: su_a {1,,3};
set:N: su_b {2,,4};
set:N: su_union = su_a ∪ su_b;
run_assert_eq_i(su_union.size(), 4, "unicode UNION size = 4");

--- string set
set:S: st_words {"apple", "banana", "cherry"};
run_assert(st_words.contains("banana"), "string set contains banana");

--- boolean set
set:B: st_bools {true, false};
run_assert_eq_i(st_bools.size(), 2, "bool set size = 2");

--- rational set with step
set:Q: st_halves {0.0,,1.0 @step 0.5};
run_assert(st_halves.contains(0.5), "Q set step 0.5 contains 0.5");

--- for loop over set
i: st_sum = 0;
set:N: st_iter_set {1,,4};
for st_p in st_iter_set do;
    st_sum = st_sum + st_p;
end;
run_assert_eq_i(st_sum, 10, "set for loop 1+2+3+4 = 10");

--- random.choice from set
set:N: rnd_pool {1,,100};
i: rnd_picked = random.choice from rnd_pool;
run_assert(rnd_picked >= 1 AND rnd_picked <= 100, "random.choice in range 1..100");

--- ============================================================
--- SECTION 20: MAPS
--- ============================================================
>! "";
>! "=== SECTION 20: MAPS ===";

map: mp_ages {
    schema = [s <-> i]
    data = ["alice" :: 30, "bob" :: 25]
};

run_assert_eq_i(mp_ages.size(), 2, "map size = 2");
run_assert(mp_ages.contains("alice"), "map contains alice");
run_assert(NOT mp_ages.contains("carol"), "map not contains carol");
run_assert_eq_i(mp_ages.get("alice"), 30, "map get alice = 30");

mp_ages.insert("carol", 28);
run_assert_eq_i(mp_ages.size(), 3, "map insert -> size 3");
run_assert_eq_i(mp_ages.get("carol"), 28, "map get carol = 28");

mp_ages.remove("bob");
run_assert_eq_i(mp_ages.size(), 2, "map remove bob -> size 2");
run_assert(NOT mp_ages.contains("bob"), "map bob removed");

--- keys and values
array:s: mp_keys = mp_ages.keys();
run_assert_eq_i(mp_keys.size(), 2, "map keys size = 2");

array:i: mp_vals = mp_ages.values();
run_assert_eq_i(mp_vals.size(), 2, "map values size = 2");

--- empty map
map: mp_empty {
    schema = [s <-> i]
    data = [EMPTY]
};
run_assert_eq_i(mp_empty.size(), 0, "empty map size = 0");

--- clear
mp_empty.insert("x", 1);
mp_empty.clear();
run_assert_eq_i(mp_empty.size(), 0, "map clear -> size 0");

--- ============================================================
--- SECTION 21: TABLES
--- ============================================================
>! "";
>! "=== SECTION 21: TABLES ===";

table: tb_products {
    columns = [id :: i @auto, name :: s, price :: f]
    rows = [("Laptop", 2999.99), ("Phone", 1499.50)]
};

run_assert_eq_i(tb_products.count(), 2, "table count = 2");

--- row access
s: tb_name0 = tb_products[0].name;
f: tb_price1 = tb_products[1].price;
run_assert_eq_s(tb_name0, "Laptop",  "table[0].name = Laptop");
run_assert_eq_f(tb_price1, 1499.50, "table[1].price = 1499.50");

--- get method
s: tb_get_name = tb_products.get(0).name;
run_assert_eq_s(tb_get_name, "Laptop", "table.get(0).name = Laptop");

--- insert / add
tb_products.insert("Tablet", 899.99);
run_assert_eq_i(tb_products.count(), 3, "table insert -> count 3");

tb_products.insert("Watch", 299.99);
run_assert_eq_i(tb_products.count(), 4, "table add(insert) -> count 4");

--- delete
tb_products.delete(3);
run_assert_eq_i(tb_products.count(), 3, "table delete -> count 3");

--- update
tb_products.update(0, ["Updated Laptop", 3499.99]);
s: tb_upd_name = tb_products[0].name;
run_assert_eq_s(tb_upd_name, "Updated Laptop", "table update name");

--- where
table: tb_expensive = tb_products.where(price > 1000.0);
run_assert_eq_i(tb_expensive.count(), 2, "table where price>1000 count = 2");

table: tb_has_name = tb_products.where(name HAS "Laptop");
run_assert_eq_i(tb_has_name.count(), 1, "table where name HAS Laptop = 1");

--- empty table
table: tb_logs {
    columns = [id :: i @auto, msg :: s]
    rows = [EMPTY]
};
run_assert_eq_i(tb_logs.count(), 0, "empty table count = 0");

--- join
table: tb_orders {
    columns = [oid :: i @auto, uid :: i, item :: s]
    rows = [(1, "book"), (1, "pen"), (2, "bag")]
};

table: tb_users {
    columns = [uid :: i, uname :: s]
    rows = [(1, "Alice"), (2, "Bob")]
};

table: tb_joined = tb_users.join(tb_orders, "uid", "uid");
run_assert_eq_i(tb_joined.count(), 3, "table join count = 3");

