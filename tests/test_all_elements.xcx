>! "";
>! "=== SECTION 9: IF / ELSEIF / ELSE ===";

i: if_score = 75;
s: if_grade;

if (if_score >= 90) then;
    if_grade = "A";
elif (if_score >= 75) then;
    if_grade = "B";
elf (if_score >= 60) then;
    if_grade = "C";
els;
    if_grade = "F";
end;

run_assert_eq_s(if_grade, "B", "if/elif/elf/els grade B");

--- nested if
i: nest_val = 5;
b: nest_result = false;

if (nest_val > 0) then;
    if (nest_val < 10) then;
        nest_result = true;
    end;
end;

run_assert(nest_result, "nested if both true");

