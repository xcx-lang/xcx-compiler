--- XCX 2.2 FULL ELEMENT COVERAGE TEST SUITE
--- Covers: types, variables, constants, operators, control flow,
---         functions, fibers, collections, dates, json, http client,
---         std lib (crypto, store, env, random), string methods, i/o

func run_assert(b: condition, s: label) {
    if (condition) then;
        >! "  OK: " + label;
    else;
        halt.error >! "  FAIL: " + label;
    end;
};

func run_assert_eq_i(i: actual, i: expected, s: label) {
    if (actual == expected) then;
        >! "  OK: " + label;
    else;
        halt.error >! "  FAIL: " + label + " | got: " + s(actual) + " expected: " + s(expected);
    end;
};

func run_assert_eq_s(s: actual, s: expected, s: label) {
    if (actual == expected) then;
        >! "  OK: " + label;
    else;
        halt.error >! "  FAIL: " + label + " | got: " + actual + " expected: " + expected;
    end;
};

func run_assert_eq_f(f: actual, f: expected, s: label) {
    if (actual == expected) then;
        >! "  OK: " + label;
    else;
        halt.error >! "  FAIL: " + label;
    end;
};

--- ============================================================
--- SECTION 1: SIMPLE TYPES AND DEFAULT VALUES
--- ============================================================
>! "";
>! "=== SECTION 1: SIMPLE TYPES AND DEFAULT VALUES ===";

i: sv_int;
f: sv_float;
s: sv_str;
b: sv_bool;

run_assert_eq_i(sv_int, 0, "default int is 0");
run_assert_eq_f(sv_float, 0.0, "default float is 0.0");
run_assert_eq_s(sv_str, "", "default string is empty");
run_assert(sv_bool == false, "default bool is false");

i: tv_int   = 42;
f: tv_float = 3.14;
s: tv_str   = "hello";
b: tv_bool  = true;

run_assert_eq_i(tv_int, 42, "int literal 42");
run_assert_eq_f(tv_float, 3.14, "float literal 3.14");
run_assert_eq_s(tv_str, "hello", "string literal hello");
run_assert(tv_bool == true, "bool literal true");

--- negative values
i: neg_int   = -7;
f: neg_float = -0.5;

run_assert_eq_i(neg_int, -7, "negative int -7");
run_assert_eq_f(neg_float, -0.5, "negative float -0.5");

--- ============================================================
--- SECTION 2: CONSTANTS
--- ============================================================
>! "";
>! "=== SECTION 2: CONSTANTS ===";

const i: CONST_MAX   = 1024;
const s: CONST_VER   = "2.2.0";
const f: CONST_PI    = 3.14159;
const b: CONST_FLAG  = true;

run_assert_eq_i(CONST_MAX, 1024, "const int 1024");
run_assert_eq_s(CONST_VER, "2.2.0", "const string 2.2.0");
run_assert(CONST_PI > 3.14, "const float pi > 3.14");
run_assert(CONST_FLAG == true, "const bool true");

--- ============================================================
--- SECTION 3: ARITHMETIC OPERATORS
--- ============================================================
>! "";
>! "=== SECTION 3: ARITHMETIC OPERATORS ===";

i: ao_a = 10;
i: ao_b = 3;

run_assert_eq_i(ao_a + ao_b, 13,   "10 + 3 = 13");
run_assert_eq_i(ao_a - ao_b, 7,    "10 - 3 = 7");
run_assert_eq_i(ao_a * ao_b, 30,   "10 * 3 = 30");
run_assert_eq_i(ao_a / ao_b, 3,    "10 / 3 = 3 (truncate)");
run_assert_eq_i(ao_a % ao_b, 1,    "10 % 3 = 1");
run_assert_eq_i(2 ^ 10, 1024,      "2 ^ 10 = 1024");
run_assert_eq_i(48 ++ 77, 4877,    "48 ++ 77 = 4877");

--- unary negation
i: unary_neg = -ao_a;
run_assert_eq_i(unary_neg, -10, "unary negation -10");

--- float arithmetic
f: fa = 1.5;
f: fb = 0.5;
run_assert_eq_f(fa + fb, 2.0, "1.5 + 0.5 = 2.0");
run_assert_eq_f(fa - fb, 1.0, "1.5 - 0.5 = 1.0");
run_assert_eq_f(fa * fb, 0.75, "1.5 * 0.5 = 0.75");

--- ============================================================
--- SECTION 4: COMPARISON OPERATORS
--- ============================================================
>! "";
>! "=== SECTION 4: COMPARISON OPERATORS ===";

i: co_x = 5;
i: co_y = 10;

run_assert(co_x == 5,       "5 == 5");
run_assert(co_x != co_y,    "5 != 10");
run_assert(co_x < co_y,     "5 < 10");
run_assert(co_y > co_x,     "10 > 5");
run_assert(co_x <= 5,       "5 <= 5");
run_assert(co_y >= 10,      "10 >= 10");
run_assert(NOT (co_x > co_y), "NOT 5 > 10");

--- ============================================================
--- SECTION 5: LOGICAL OPERATORS
--- ============================================================
>! "";
>! "=== SECTION 5: LOGICAL OPERATORS ===";

b: lo_t = true;
b: lo_f = false;

run_assert(lo_t AND lo_t,    "true AND true");
run_assert(NOT (lo_t AND lo_f), "NOT (true AND false)");
run_assert(lo_t OR lo_f,     "true OR false");
run_assert(NOT lo_f,         "NOT false");
run_assert(NOT NOT lo_t,     "NOT NOT true == true");

--- aliases
run_assert(lo_t && lo_t,    "true && true");
run_assert(lo_t || lo_f,    "true || false");
run_assert(!! lo_f,         "!! false == true");

