--- ============================================================
--- SECTION 35: COMPLEX EXPRESSIONS AND EDGE CASES
--- ============================================================
>! "";
>! "=== SECTION 35: COMPLEX EXPRESSIONS ===";

--- chained method calls
s: ce_chain = "  hello world  ".trim().upper().replace(" ", "_");
run_assert_eq_s(ce_chain, "HELLO_WORLD", "chain trim.upper.replace");

--- complex boolean expression
i: ce_n = 7;
b: ce_complex = (ce_n > 5 AND ce_n < 10) OR (ce_n == 0);
run_assert(ce_complex, "complex bool (7>5 AND 7<10) OR 7==0 = true");

--- string HAS chained with AND
s: ce_text = "XCX Version 2.2";
b: ce_has  = (ce_text HAS "XCX") AND (ce_text HAS "2.2");
run_assert(ce_has, "HAS both substrings");

--- integer arithmetic chain
i: ce_math = (3 + 4) * 2 - (10 / 5) + 1;
run_assert_eq_i(ce_math, 13, "(3+4)*2 - 10/5 + 1 = 13");

--- modulo and comparison
b: ce_even = (ce_math % 2 == 1);
run_assert(ce_even, "13 % 2 == 1 (odd)");

--- set operations chain
set:N: ce_sa {1,,5};
set:N: ce_sb {4,,8};
set:N: ce_sc {5,,9};
set:N: ce_combined = (ce_sa UNION ce_sb) INTERSECTION ce_sc;
run_assert(ce_combined.contains(5), "chained set ops contains 5");
run_assert(ce_combined.contains(8), "chained set ops contains 8");

