--- SECTION 6: STRING OPERATORS AND METHODS
--- ============================================================
>! "";
>! "=== SECTION 6: STRING OPERATORS AND METHODS ===";

s: sm_base   = "  XCX-Language  ";
s: sm_concat = "Hello" + " " + "World";

run_assert_eq_s(sm_concat, "Hello World", "string concat");
run_assert("Search" HAS "ear", "HAS substring true");
run_assert(NOT ("Search" HAS "xyz"), "HAS substring false");

--- auto-convert to string
s: sm_numstr = "Value: " + 42;
run_assert_eq_s(sm_numstr, "Value: 42", "int to string concat");

--- length property
run_assert_eq_i("hello".length, 5, "length 5");
run_assert_eq_i("".length, 0, "empty length 0");

--- methods
s: sm_trimmed  = sm_base.trim();
s: sm_upper    = "hello".upper();
s: sm_lower    = "HELLO".lower();
s: sm_replaced = "a-b-c".replace("-", "_");
s: sm_sliced   = "Programming".slice(0, 4);
i: sm_idx      = "Programming".indexOf("gram");
b: sm_starts   = "Hello".startsWith("He");
b: sm_ends     = "Hello".endsWith("lo");
i: sm_parsed_i = "25".toInt();
f: sm_parsed_f = "3.5".toFloat();

run_assert_eq_s(sm_trimmed, "XCX-Language", "trim");
run_assert_eq_s(sm_upper, "HELLO", "upper");
run_assert_eq_s(sm_lower, "hello", "lower");
run_assert_eq_s(sm_replaced, "a_b_c", "replace");
run_assert_eq_s(sm_sliced, "Prog", "slice 0..4");
run_assert_eq_i(sm_idx, 3, "indexOf gram = 3");
run_assert(sm_starts, "startsWith He");
run_assert(sm_ends, "endsWith lo");
run_assert_eq_i(sm_parsed_i, 25, "toInt 25");
run_assert_eq_f(sm_parsed_f, 3.5, "toFloat 3.5");

--- lastIndexOf
i: li_idx = "abcabc".lastIndexOf("a");
run_assert_eq_i(li_idx, 3, "lastIndexOf a = 3");

