--- ============================================================
--- SECTION 29: FIBER AS FUNCTION PARAMETER
--- ============================================================
>! "";
>! "=== SECTION 29: FIBER AS FUNCTION PARAMETER ===";

fiber fp_source(-> i) {
    yield 10;
    yield 20;
    yield 30;
    return 0;
};

func fp_sum_fiber(fiber:i: fp_f -> i) {
    i: fp_total = 0;
    while (fp_f.isDone() == false) do;
        i: fp_v = fp_f.next();
        fp_total = fp_total + fp_v;
    end;
    return fp_total;
};

fiber:i: fp_inst = fp_source();
i: fp_result = fp_sum_fiber(fp_inst);
run_assert_eq_i(fp_result, 60, "fiber as param sum = 60");

