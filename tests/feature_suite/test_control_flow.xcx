--- test_control_flow.xcx
--- if/elseif/elif/elf/else/els, for, while, break, continue

>! "Running test_control_flow.xcx...";

--- If Aliases
i: score = 75;
s: grade = "";

if (score >= 90) then;
    grade = "A";
elif (score >= 75) then;
    grade = "B";
elf (score >= 60) then;
    grade = "C";
els;
    grade = "F";
end;

if (grade != "B") then; 
    halt.error >! "If/elif/elf/els failed"; 
end;

--- While loop
i: loop_cnt = 0;
while (loop_cnt < 5) do;
    loop_cnt = loop_cnt + 1;
end;
if (loop_cnt != 5) then; 
    halt.error >! "While loop failed"; 
end;

--- For Range
i: sum_range = 0;
for i_loop in 1 to 3 do;
    sum_range = sum_range + i_loop;
end;
if (sum_range != 6) then; 
    halt.error >! "For range failed"; 
end;

--- For Step
i: sum_step = 0;
for j_loop in 0 to 6 @step 2 do;
    sum_step = sum_step + j_loop;
end;
if (sum_step != 12) then; 
    halt.error >! "For step failed"; 
end;

--- For Collection (Array)
array:i: arr_nums {10, 20, 30};
i: sum_arr = 0;
for el_arr in arr_nums do;
    sum_arr = sum_arr + el_arr;
end;
if (sum_arr != 60) then; 
    halt.error >! "For collection (array) failed"; 
end;

--- For Collection (Set)
 set:N: set_nums {10, 20, 30};
 i: sum_set = 0;
 for s_el in set_nums do;
     sum_set = sum_set + s_el;
 end;
 if (sum_set != 60) then; 
    halt.error >! "For collection (set) failed"; 
 end;

--- Break and Continue
i: break_cnt = 0;
for n_loop in 1 to 10 do;
    if (n_loop % 2 == 0) then; continue; end;
    if (n_loop > 5) then; break; end;
    break_cnt = break_cnt + n_loop;
end;
if (break_cnt != 9) then; 
    halt.error >! "Break/Continue failed"; 
end;

>! "test_control_flow.xcx passed.";
